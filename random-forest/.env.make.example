# Copy this file to `.env.make` on the HPC and edit the paths for your account.

# Code location on HPC
PROJECT_ROOT ?= /mnt/research/your_user_or_project/sea-ice/random-forest

# Data and generated outputs location on HPC
DATA_ROOT ?= /mnt/research/your_user_or_project/rf_arctic_project

# If the raw PFT zip archives are stored separately, point here.
PFT_ZIP_DIR ?= /mnt/research/your_user_or_project/rf_arctic_project/arctic-pfts

# Python executable inside your HPC environment
# Recommended for Bowdoin: a project-local virtual environment
PYTHON ?= /mnt/research/your_user_or_project/sea-ice/random-forest/.venv/bin/python
